{
  "name": "localleaf",
  "version": "0.1.0",
  "private": true,
  "description": "LocalLeaf host-powered Overleaf-style collaboration app.",
  "main": "src/desktop/main.js",
  "scripts": {
    "start": "node src/server/index.js",
    "dev:desktop": "electron .",
    "install:tectonic": "powershell -ExecutionPolicy Bypass -File scripts/install-tectonic.ps1",
    "package:win": "electron-builder --win nsis --x64",
    "test": "node --test tests/*.test.js"
  },
  "keywords": [
    "latex",
    "collaboration",
    "overleaf",
    "localleaf"
  ],
  "author": "",
  "license": "UNLICENSED",
  "build": {
    "appId": "dev.localleaf.host",
    "productName": "LocalLeaf Host",
    "afterPack": "scripts/after-pack.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "build/**/*",
      "samples/**/*",
      "package.json",
      "README.md"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "cloudflared.exe",
          "tectonic.exe",
          "licenses/**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "signExts": [
        "!.exe"
      ],
      "verifyUpdateCodeSignature": false,
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "localtunnel": "^2.0.2",
    "ws": "^8.18.3"
  },
  "overrides": {
    "axios": "1.15.2"
  }
}
