{
  "name": "localleaf",
  "version": "0.1.0",
  "private": true,
  "description": "LocalLeaf host-powered Overleaf-style collaboration app.",
  "main": "src/desktop/main.js",
  "scripts": {
    "start": "node src/server/index.js",
    "dev:desktop": "electron .",
    "prepare:binaries": "node scripts/prepare-binaries.js",
    "install:tectonic": "powershell -ExecutionPolicy Bypass -File scripts/install-tectonic.ps1",
    "package:win": "electron-builder --win nsis --x64",
    "package:mac:x64": "electron-builder --mac dmg zip --x64",
    "package:mac:arm64": "electron-builder --mac dmg zip --arm64",
    "test": "node --test tests/*.test.js"
  },
  "keywords": [
    "latex",
    "collaboration",
    "overleaf",
    "localleaf"
  ],
  "author": "",
  "license": "UNLICENSED",
  "build": {
    "appId": "dev.localleaf.host",
    "productName": "LocalLeaf Host",
    "afterPack": "scripts/after-pack.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "build/**/*",
      "samples/**/*",
      "package.json",
      "README.md"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "cloudflared*",
          "tectonic*",
          "licenses/**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "identity": "-",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "LocalLeaf Host",
      "backgroundColor": "#ffffff"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "signExts": [
        "!.exe"
      ],
      "verifyUpdateCodeSignature": false,
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "localtunnel": "^2.0.2",
    "ws": "^8.18.3"
  },
  "overrides": {
    "axios": "1.15.2"
  }
}
